# ============================================================
# ChainSolutions — Configuration d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# URL de la base de données SQLite (chemin dans le volume Docker)
DATABASE_URL="file:/app/data/chainsolutions.db"

# Clé secrète NextAuth (générer avec : openssl rand -base64 32)
NEXTAUTH_SECRET="your-nextauth-secret-change-this"

# URL publique de l'application
NEXTAUTH_URL="https://wwx.chainsolutions.fr"
NEXT_PUBLIC_SITE_URL="https://wwx.chainsolutions.fr"

# Email admin (destinataire des messages de contact)
ADMIN_EMAIL="contact@chainsolutions.fr"

# Clé API Resend pour l'envoi d'emails (https://resend.com)
RESEND_API_KEY="re_your_resend_api_key"
